---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  keyword: string;
  serviceName: string;
  serviceIcon: string;
  benefits: string[];
  features: { title: string; desc: string }[];
  faqs: { q: string; a: string }[];
  ctaText: string;
}

const {
  title,
  description,
  keyword,
  serviceName,
  serviceIcon,
  benefits,
  features,
  faqs,
  ctaText,
} = Astro.props;

const siteUrl = 'https://scalio-web.vercel.app';
const currentUrl = `${siteUrl}${Astro.url.pathname}`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": serviceName,
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Scalio",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lima",
      "addressRegion": "Lima",
      "addressCountry": "PE"
    }
  },
  "areaServed": {
    "@type": "Country",
    "name": "Perú"
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "PEN",
    "areaServed": "Perú"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Servicios",
      "item": `${siteUrl}/servicios`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": serviceName,
      "item": currentUrl
    }
  ]
};
---

<Layout 
  title={title}
  description={description}
  canonical={Astro.url.pathname}
  schema={serviceSchema}
>
  <a href="#contenido-principal" class="skip-link">Saltar al contenido principal</a>

  <Nav />

  <main id="contenido-principal">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" style="padding: 1rem 2rem; max-width: 1200px; margin: 0 auto;">
      <ol style="list-style: none; display: flex; gap: 0.5rem; font-size: 0.9rem; color: var(--text-secondary, #64748b);">
        <li><a href="/" style="color: var(--accent, #3b82f6); text-decoration: none;">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/servicios" style="color: var(--accent, #3b82f6); text-decoration: none;">Servicios</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page">{serviceName}</li>
      </ol>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />

    <!-- HERO DEL SERVICIO -->
    <section aria-label={`Servicio de ${serviceName}`} style="padding: 3rem 2rem; text-align: center; max-width: 900px; margin: 0 auto;">
      <span style="font-size: 4rem; display: block; margin-bottom: 1rem;">{serviceIcon}</span>
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 1rem; line-height: 1.2;">
        {serviceName} en Perú
      </h1>
      <p style="font-size: clamp(1rem, 2vw, 1.25rem); color: var(--text-secondary, #64748b); max-width: 600px; margin: 0 auto 2rem; line-height: 1.6;">
        {description}
      </p>
      <a 
        href="/contacto" 
        style="background: var(--accent, #3b82f6); color: white; padding: 1rem 2.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; display: inline-block; font-size: 1.1rem; min-height: 48px;"
      >
        {ctaText}
      </a>
    </section>

    <!-- BENEFICIOS -->
    <section aria-label={`Beneficios de ${serviceName}`} style="padding: 3rem 2rem; background: var(--bg-secondary, #f8fafc);">
      <div style="max-width: 1000px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: 1.75rem; margin-bottom: 2rem;">
          ¿Por qué invertir en {serviceName}?
        </h2>
        <ul style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; list-style: none;">
          {benefits.map(benefit => (
            <li style="padding: 1.5rem; background: white; border-radius: 8px; border: 1px solid var(--border, #e2e8f0); display: flex; align-items: flex-start; gap: 0.75rem;">
              <span style="color: var(--accent, #3b82f6); font-size: 1.25rem; flex-shrink: 0;">✓</span>
              <span>{benefit}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CARACTERÍSTICAS -->
    <section aria-label={`Características de ${serviceName}`} style="padding: 3rem 2rem;">
      <div style="max-width: 1000px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: 1.75rem; margin-bottom: 2rem;">
          Lo que incluye nuestro servicio
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
          {features.map(feature => (
            <article style="padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border, #e2e8f0);">
              <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--accent, #3b82f6);">{feature.title}</h3>
              <p style="color: var(--text-secondary, #64748b); line-height: 1.5;">{feature.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESO -->
    <section aria-label="Nuestro proceso de trabajo" style="padding: 3rem 2rem; background: var(--bg-secondary, #f8fafc);">
      <div style="max-width: 800px; margin: 0 auto; text-align: center;">
        <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Cómo trabajamos</h2>
        <ol style="list-style: none; display: grid; gap: 1.5rem; text-align: left;">
          <li style="display: flex; gap: 1rem; align-items: flex-start;">
            <span style="background: var(--accent, #3b82f6); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">1</span>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Diagnóstico gratuito</h3>
              <p style="color: var(--text-secondary, #64748b); font-size: 0.95rem;">Analizamos tu situación actual y definimos objetivos claros.</p>
            </div>
          </li>
          <li style="display: flex; gap: 1rem; align-items: flex-start;">
            <span style="background: var(--accent, #3b82f6); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">2</span>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Propuesta personalizada</h3>
              <p style="color: var(--text-secondary, #64748b); font-size: 0.95rem;">Recibes un plan de trabajo con tiempos, costos y entregables.</p>
            </div>
          </li>
          <li style="display: flex; gap: 1rem; align-items: flex-start;">
            <span style="background: var(--accent, #3b82f6); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">3</span>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Desarrollo ágil</h3>
              <p style="color: var(--text-secondary, #64748b); font-size: 0.95rem;">Trabajamos en sprints con revisiones semanales.</p>
            </div>
          </li>
          <li style="display: flex; gap: 1rem; align-items: flex-start;">
            <span style="background: var(--accent, #3b82f6); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">4</span>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Entrega y soporte</h3>
              <p style="color: var(--text-secondary, #64748b); font-size: 0.95rem;">Puesta en marcha, capacitación y soporte post-lanzamiento.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- FAQ -->
    <section aria-label="Preguntas frecuentes" style="padding: 3rem 2rem;">
      <div style="max-width: 800px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: 1.75rem; margin-bottom: 2rem;">Preguntas frecuentes sobre {serviceName}</h2>
        {faqs.map(faq => (
          <details style="margin-bottom: 1rem; padding: 1.25rem; background: var(--bg-secondary, #f8fafc); border-radius: 8px; border: 1px solid var(--border, #e2e8f0);">
            <summary style="font-weight: 600; cursor: pointer; font-size: 1rem;">{faq.q}</summary>
            <p style="margin-top: 0.75rem; color: var(--text-secondary, #64748b); line-height: 1.6;">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- CTA FINAL -->
    <section aria-label="Llamada a la acción" style="padding: 4rem 2rem; text-align: center; background: var(--bg-secondary, #f8fafc);">
      <h2 style="font-size: 1.75rem; margin-bottom: 1rem;">¿Listo para empezar con {serviceName}?</h2>
      <p style="color: var(--text-secondary, #64748b); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
        Agenda una consulta gratuita y descubre cómo podemos ayudarte a escalar tu negocio.
      </p>
      <a 
        href="/contacto" 
        style="background: var(--accent, #3b82f6); color: white; padding: 1rem 2.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; display: inline-block; font-size: 1.1rem; min-height: 48px;"
      >
        Solicitar cotización gratis →
      </a>
    </section>
  </main>

  <Footer />
</Layout>
