---
interface Props {
  currentPage?: string;
}
const { currentPage = "/" } = Astro.props;
---

<nav id="nav" class="glass">
  <div class="nav-inner">
    <a href="/" class="nav-logo" data-cursor-expand>
      Scal<em>io</em>
    </a>

    <div class="nav-links">
      <a
        href="/"
        class:list={["nav-link", { active: currentPage === "/" }]}
        data-cursor-expand
      >
        Inicio
      </a>
      <a
        href="/scalio"
        class:list={["nav-link", { active: currentPage === "/scalio" }]}
        data-cursor-expand
      >
        Scalio
      </a>
      <a
        href="/contacto"
        class:list={["nav-link", { active: currentPage === "/contacto" }]}
        data-cursor-expand
      >
        Contacto
      </a>
    </div>

    <a href="/contacto" class="nav-cta" data-cursor-expand> Empezar → </a>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Abrir menú">
      <span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu glass" id="mobile-menu">
  <div class="mobile-menu-inner">
    <a href="/" class="mobile-link" data-cursor-expand>Inicio</a>
    <a href="/scalio" class="mobile-link" data-cursor-expand>Scalio</a>
    <a href="/contacto" class="mobile-link" data-cursor-expand>Contacto</a>
  </div>
</div>

<style>
  nav {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 800;
    border-radius: 100px;
    width: min(calc(100% - 3rem), 900px);
    opacity: 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.5rem;
    gap: 1rem;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--white);
    white-space: nowrap;
  }

  .nav-logo em {
    font-style: italic;
    color: var(--yellow);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    color: var(--white-muted);
    position: relative;
    transition: color 0.3s ease;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--yellow);
    transition: width 0.3s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--white);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-cta {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--dark);
    background: var(--yellow);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-weight: 600;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: var(--white);
    transform: scale(1.05);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--white);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .nav-hamburger.open span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .nav-hamburger.open span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    top: 5rem;
    left: 50%;
    transform: translateX(-50%) scaleY(0);
    transform-origin: top;
    z-index: 799;
    border-radius: 20px;
    width: min(calc(100% - 3rem), 900px);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: none;
  }

  .mobile-menu.open {
    transform: translateX(-50%) scaleY(1);
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem;
    gap: 1.5rem;
  }

  .mobile-link {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--white);
    transition: color 0.3s;
  }

  .mobile-link:hover {
    color: var(--yellow);
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-cta {
      display: none;
    }
    .nav-hamburger {
      display: flex;
    }
    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  // Nav enter animation
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof gsap !== "undefined") {
      gsap.to("#nav", {
        opacity: 1,
        y: 0,
        duration: 1,
        delay: 0.5,
        ease: "expo.out",
      });
    }

    // Hamburger toggle
    const hamburger = document.getElementById("nav-hamburger");
    const mobileMenu = document.getElementById("mobile-menu");

    hamburger?.addEventListener("click", () => {
      hamburger.classList.toggle("open");
      mobileMenu?.classList.toggle("open");
    });

    // Scroll hide/show nav
    let lastY = 0;
    const nav = document.getElementById("nav");

    window.addEventListener(
      "scroll",
      () => {
        const scrollY = window.scrollY;
        if (scrollY < 100) {
          nav?.style.setProperty("opacity", "1");
          return;
        }
        if (scrollY > lastY + 10) {
          gsap?.to("#nav", {
            y: -100,
            opacity: 0,
            duration: 0.4,
            ease: "power2.inOut",
          });
        } else if (scrollY < lastY - 10) {
          gsap?.to("#nav", {
            y: 0,
            opacity: 1,
            duration: 0.4,
            ease: "power2.out",
          });
        }
        lastY = scrollY;
      },
      { passive: true },
    );
  });
</script>
