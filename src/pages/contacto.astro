---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";
---

<Layout
  title="Scalio — Contacto"
  description="Hablemos. Cuéntanos tu proyecto y te respondemos rápido."
>
  <TransitionOverlay />
  <Nav currentPage="/contacto" />

  <main class="contact-page">
    <!-- ─── PAGE HEADER ────────────────── -->
    <section class="contact-hero">
      <div class="container">
        <p class="page-label" id="label-in">Contacto</p>
        <h1 id="title-in">
          Hablemos sobre<br />
          <em>tu proyecto.</em>
        </h1>
        <p class="hero-sub" id="sub-in">
          Cuéntanos tu idea y te responderemos<br />en menos de 24 horas.
        </p>
      </div>
    </section>

    <!-- ─── CONTACT BODY ──────────────── -->
    <section class="contact-body">
      <div class="container">
        <div class="contact-grid">
          <!-- Form -->
          <div class="form-side" id="form-in">
            <form id="contact-form" class="contact-form glass" novalidate>
              <div class="form-group">
                <label for="name">Nombre completo</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Tu nombre"
                  required
                  autocomplete="name"
                />
              </div>

              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="tu@email.com"
                  required
                  autocomplete="email"
                />
              </div>

              <div class="form-group">
                <label for="whatsapp">WhatsApp (opcional)</label>
                <input
                  type="tel"
                  id="whatsapp"
                  name="whatsapp"
                  placeholder="+51 999 999 999"
                  autocomplete="tel"
                />
              </div>

              <div class="form-group">
                <label for="service">¿Qué necesitas?</label>
                <div class="select-wrap">
                  <select id="service" name="service">
                    <option value="">Selecciona un servicio</option>
                    <option value="landing">Landing page (1 página)</option>
                    <option value="web">Sitio web completo</option>
                    <option value="automatizacion"
                      >Automatización de procesos</option
                    >
                    <option value="todo">Web + Automatización</option>
                    <option value="otro">Otro / No sé aún</option>
                  </select>
                  <span class="select-arrow">↓</span>
                </div>
              </div>

              <div class="form-group">
                <label for="message">Cuéntanos tu proyecto</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Describe brevemente qué necesitas..."
                  required
                  rows="5"></textarea>
              </div>

              <div class="form-footer">
                <!-- <p class="form-note">
                  Respondemos en menos de 24h · Sin compromisos
                </p> -->
                <button type="submit" class="submit-btn" id="submit-btn">
                  <span class="btn-text">Enviar mensaje →</span>
                  <span class="btn-loading" aria-hidden="true">Enviando...</span
                  >
                </button>
              </div>

              <div class="form-success" id="form-success" aria-live="polite">
                <div class="success-icon">✓</div>
                <h3>¡Mensaje enviado!</h3>
                <p>
                  Te responderemos pronto. También puedes escribirnos
                  directamente por WhatsApp.
                </p>
                <a
                  href="https://wa.me/51994660039"
                  class="wa-btn"
                  target="_blank">Abrir WhatsApp →</a
                >
              </div>
            </form>
          </div>

          <!-- Info -->
          <div class="info-side" id="info-in">
            <div class="info-block">
              <p class="info-label">Contacto directo</p>
              <div class="info-links">
                <a
                  href="https://wa.me/51994660039"
                  target="_blank"
                  class="info-link"
                  data-cursor-expand
                >
                  <span class="info-link-icon">💬</span>
                  <div>
                    <strong>WhatsApp</strong>
                    <span>+51 994 660 039</span>
                  </div>
                  <span class="info-link-arrow">→</span>
                </a>
                <a
                  href="mailto:scalio.contact@gmail.com"
                  class="info-link"
                  data-cursor-expand
                >
                  <span class="info-link-icon">✉</span>
                  <div>
                    <strong>Email</strong>
                    <span>scalio.contact@gmail.com</span>
                  </div>
                  <span class="info-link-arrow">→</span>
                </a>
                <a
                  href="https://instagram.com/scalio.studio"
                  target="_blank"
                  class="info-link"
                  data-cursor-expand
                >
                  <span class="info-link-icon">◎</span>
                  <div>
                    <strong>Instagram</strong>
                    <span>@scalio.studio</span>
                  </div>
                  <span class="info-link-arrow">→</span>
                </a>
              </div>
            </div>

            <!-- Plans preview -->
            <!-- <div class="plans-preview">
              <p class="info-label">Planes</p>
              <div class="plan-row">
                <span>Básico</span>
                <span class="plan-price">S/ 500 – 800</span>
              </div>
              <div class="plan-row">
                <span>Estándar</span>
                <span class="plan-price">S/ 900 – 1500</span>
              </div>
              <div class="plan-row highlight">
                <span>Pro</span>
                <span class="plan-price">S/ 1600 – 2500</span>
              </div>
              <p class="plan-note">50% inicial · 50% contra entrega</p>
            </div> -->
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .contact-page {
    min-height: 100svh;
  }

  /* ─── Hero ────────────────────────── */
  .contact-hero {
    padding: 12rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 1.5rem;
    opacity: 0;
  }

  .contact-hero h1 {
    opacity: 0;
    margin-bottom: 1.5rem;
  }

  .contact-hero h1 em {
    font-style: italic;
    color: var(--yellow);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--white-muted);
    opacity: 0;
    line-height: 1.7;
  }

  /* ─── Body ────────────────────────── */
  .contact-body {
    padding: 6rem 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 5rem;
    align-items: start;
  }

  /* ─── Form ────────────────────────── */
  .form-side {
    opacity: 0;
  }

  .contact-form {
    padding: 3rem;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.875rem 1.125rem;
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 1rem;
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
    outline: none;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--yellow);
    background: rgba(250, 204, 21, 0.04);
  }

  .form-group input.error,
  .form-group textarea.error {
    border-color: #ef4444;
  }

  .select-wrap {
    position: relative;
  }

  .select-wrap select {
    width: 100%;
    appearance: none;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.875rem 1.125rem;
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 1rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.3s;
  }

  .select-wrap select:focus {
    border-color: var(--yellow);
  }

  .select-wrap select option {
    background: var(--dark-3);
    color: var(--white);
  }

  .select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--white-muted);
    pointer-events: none;
    font-size: 0.8rem;
  }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .form-note {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
  }

  .submit-btn {
    background: var(--yellow);
    color: var(--dark);
    border: none;
    padding: 0.9rem 2.25rem;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .submit-btn:hover {
    background: var(--white);
    transform: scale(1.04);
  }

  .submit-btn.loading .btn-text {
    opacity: 0;
  }
  .submit-btn.loading .btn-loading {
    opacity: 1;
  }

  .btn-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  /* Success state */
  .form-success {
    position: absolute;
    inset: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .form-success.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .success-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--yellow);
    color: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .form-success p {
    color: var(--white-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .wa-btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--yellow);
    color: var(--dark);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.3s;
  }

  .wa-btn:hover {
    background: var(--white);
  }

  /* ─── Info Side ──────────────────── */
  .info-side {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    opacity: 0;
  }

  .info-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-muted);
    margin-bottom: 1rem;
  }

  .info-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--dark-2);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .info-link:hover {
    border-color: rgba(250, 204, 21, 0.3);
    background: rgba(250, 204, 21, 0.04);
    transform: translateX(4px);
  }

  .info-link-icon {
    font-size: 1.1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(250, 204, 21, 0.1);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .info-link div {
    flex: 1;
  }

  .info-link strong {
    display: block;
    font-size: 0.85rem;
    color: var(--white);
    font-weight: 500;
    margin-bottom: 0.1rem;
  }

  .info-link span:not(.info-link-icon):not(.info-link-arrow) {
    font-size: 0.8rem;
    color: var(--white-muted);
  }

  .info-link-arrow {
    color: var(--white-muted);
    font-size: 0.9rem;
    transition: all 0.3s;
  }

  .info-link:hover .info-link-arrow {
    color: var(--yellow);
    transform: translateX(4px);
  }

  .info-text {
    font-size: 0.95rem;
    color: var(--white-muted);
    line-height: 1.7;
  }

  .plans-preview {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    background: var(--dark-2);
  }

  .plan-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--white-muted);
  }

  .plan-row:last-of-type {
    border-bottom: none;
  }

  .plan-row.highlight {
    color: var(--white);
  }

  .plan-price {
    color: var(--yellow);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .plan-note {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.06em;
    margin-top: 1rem;
    text-align: center;
    text-transform: uppercase;
  }

  /* ─── Responsive ─────────────────── */
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    .contact-form {
      padding: 2rem;
    }
    .form-footer {
      flex-direction: column;
      align-items: stretch;
    }
    .submit-btn {
      text-align: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof gsap !== "undefined") {
      // Hero entrance
      const tl = gsap.timeline({ delay: 0.2 });
      tl.to(".page-label", {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "expo.out",
      })
        .to(
          ".contact-hero h1",
          { opacity: 1, y: 0, duration: 0.9, ease: "expo.out" },
          "-=0.2",
        )
        .to(
          ".hero-sub",
          { opacity: 1, y: 0, duration: 0.7, ease: "expo.out" },
          "-=0.5",
        )
        .to(
          "#form-in",
          { opacity: 1, y: 0, duration: 0.8, ease: "expo.out" },
          "-=0.3",
        )
        .to(
          "#info-in",
          { opacity: 1, y: 0, duration: 0.8, ease: "expo.out" },
          "-=0.6",
        );
    }

    // Form submission
    const form = document.getElementById("contact-form");
    const btn = document.getElementById("submit-btn");
    const success = document.getElementById("form-success");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();

      const name = (document.getElementById("name") as HTMLInputElement)?.value;
      const email = (document.getElementById("email") as HTMLInputElement)
        ?.value;
      const service = (document.getElementById("service") as HTMLSelectElement)
        ?.value;
      const message = (
        document.getElementById("message") as HTMLTextAreaElement
      )?.value;

      // Basic validation
      let valid = true;
      [
        document.getElementById("name"),
        document.getElementById("email"),
        document.getElementById("message"),
      ].forEach((el) => {
        if (el && !(el as HTMLInputElement).value.trim()) {
          el.classList.add("error");
          valid = false;
        } else {
          el?.classList.remove("error");
        }
      });

      if (!valid) return;

      // Show loading state
      btn?.classList.add("loading");

      // Build WhatsApp message
      const waMsg = `Hola Scalio! Mi nombre es ${name} (${email}).%0A%0AServicio: ${service || "Sin especificar"}%0A%0AMensaje: ${message}`;
      const waURL = `https://wa.me/51999999999?text=${waMsg}`;

      // Small delay for UX
      setTimeout(() => {
        btn?.classList.remove("loading");
        success?.classList.add("visible");
        window.open(waURL, "_blank");
      }, 800);
    });

    // Remove error class on input
    document
      .querySelectorAll(".form-group input, .form-group textarea")
      .forEach((el) => {
        el.addEventListener("input", () => el.classList.remove("error"));
      });
  });
</script>
