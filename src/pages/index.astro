---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";

// Schema FAQPage para Featured Snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cuánto cuesta una página web en Perú?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "El costo varía según complejidad. En Scalio ofrecemos desarrollo web estratégico desde S/999 para MYPES y emprendedores en Perú, incluyendo diseño responsive, SEO básico y optimización para conversiones. Solicita tu cotización personalizada sin compromiso.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué es la automatización de procesos para empresas?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "La automatización de procesos permite a las empresas peruanas reducir tareas manuales repetitivas usando tecnología. En Scalio automatizamos respuestas de WhatsApp, captura de leads, integraciones con Google Sheets, CRMs y flujos de seguimiento, reduciendo el trabajo manual hasta en un 60%.",
      },
    },
    {
      "@type": "Question",
      name: "¿Trabajan con emprendedores y MYPES en Perú?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, en Scalio trabajamos específicamente con emprendedores, startups y MYPES en Perú. Entendemos las restricciones de presupuesto y tiempo de las empresas en crecimiento, por eso ofrecemos soluciones tecnológicas escalables que crecen junto con tu negocio.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuánto tiempo tardan en entregar una página web?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Una landing page o web corporativa básica toma entre 2 y 3 semanas. Proyectos más complejos como e-commerce o plataformas personalizadas pueden tomar de 4 a 8 semanas. Siempre entregamos con fecha exacta y mantenemos comunicación constante durante el proceso.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué incluye el desarrollo web en Scalio?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nuestro desarrollo web incluye: diseño UX/UI estratégico orientado a conversiones, desarrollo con tecnología moderna (Astro), SEO técnico básico, velocidad de carga optimizada, responsive para todos los dispositivos, integración con WhatsApp Business, formularios de contacto, Google Analytics configurado y 30 días de soporte post-lanzamiento.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cómo funciona la automatización de WhatsApp para negocios?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Implementamos respuestas automáticas inteligentes en WhatsApp Business que atienden a tus clientes 24/7: mensajes de bienvenida personalizados, respuestas a preguntas frecuentes, captura de datos de leads, envío automático de catálogos y precios, confirmaciones de citas, recordatorios y seguimiento post-venta. Todo sin necesidad de aumentar tu equipo de atención al cliente.",
      },
    },
  ],
};
---

<Layout
  title="Scalio | Desarrollo Web y Automatización para MYPES en Perú"
  description="Agencia digital en Lima, Perú. Creamos páginas web estratégicas y automatizamos procesos para MYPES y emprendedores. Webs que venden, sistemas que escalan. Cotiza gratis."
  canonical="/"
  schema={faqSchema}
>
  <TransitionOverlay />
  <Nav currentPage="/" />

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 1. HERO / BANNER PRINCIPAL — OPTIMIZADO SEO                    -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="grid-overlay"></div>
    </div>

    <div class="container hero-content">
      <div class="hero-tag">
        <span class="tag-dot"></span>
        Agencia digital · Lima, Perú
      </div>

      <h1 class="hero-headline" id="hero-headline">
        <span class="line" id="line1">Tu negocio crece</span>
        <span class="line italic" id="line2">con nosotros.</span>
      </h1>

      <div class="hero-sub" id="hero-sub">
        <p class="hero-sub-main">
          Tu presencia online deja de ser gasto y <strong
            >se convierte en tu mejor empleado.</strong
          >
        </p>
        <p class="hero-sub-secondary">
          Creamos páginas web que convierten visitantes en clientes y
          automatizamos tus tareas repetitivas para que enfoques en hacer crecer
          tu negocio.
        </p>

        <div class="hero-actions">
          <a href="/contacto" class="btn-primary" data-cursor-expand>
            Hablemos de tu crecimiento
          </a>
          <a href="#proceso" class="btn-ghost" data-cursor-expand>
            Ver cómo trabajamos ↓
          </a>
        </div>

        <!-- <div class="hero-trust">
          <span class="trust-item">✓ 100% peruano</span>
          <span class="trust-separator">·</span>
          <span class="trust-item">✓ Respuesta en 24h</span>
          <span class="trust-separator">·</span>
          <span class="trust-item">✓ Soporte post-entrega</span>
        </div> -->
      </div>
    </div>

    <div class="scroll-indicator" id="scroll-indicator">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 2. MARQUEE — AMPLIADO CON KEYWORDS DEL NICHO                   -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="marquee-wrapper" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-inner">
        <span>Diseño Web</span><span class="dot">·</span>
        <span>Automatización</span><span class="dot">·</span>
        <span>SEO Estratégico</span><span class="dot">·</span>
        <span>Integración WhatsApp</span><span class="dot">·</span>
        <span>CRM & Leads</span><span class="dot">·</span>
        <span>Landing Pages</span><span class="dot">·</span>
        <span>E-Commerce</span><span class="dot">·</span>
        <span>ERP · SaaS</span><span class="dot">·</span>
        <span>Diseño Web</span><span class="dot">·</span>
        <span>Automatización</span><span class="dot">·</span>
        <span>SEO Estratégico</span><span class="dot">·</span>
        <span>Integración WhatsApp</span><span class="dot">·</span>
        <span>CRM & Leads</span><span class="dot">·</span>
        <span>Landing Pages</span><span class="dot">·</span>
        <span>E-Commerce</span><span class="dot">·</span>
        <span>ERP · SaaS</span><span class="dot">·</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 3. STATEMENT / NUESTRA MISIÓN — CON CONTEXTO SEO               -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="statement">
    <div class="container">
      <p class="statement-label reveal">Nuestra misión</p>
      <h2 class="statement-text">
        <span class="reveal-word">Existimos para hacer</span>
        <span class="reveal-word italic yellow">posible el crecimiento.</span>
        <span class="reveal-word">Nuevas presencias.</span>
        <span class="reveal-word italic">Nuevos sistemas.</span>
        <span class="reveal-word">Nuevos resultados.</span>
      </h2>

      <div class="statement-context reveal">
        <p>
          Somos una agencia digital en Lima que ayuda a crecer negocios que
          tienen ambición: <strong
            >con páginas web que venden, procesos que se automatizan y sistemas
            que escalan sin límite.
          </strong>
        </p>
        <a href="/scalio" class="btn-ghost statement-cta" data-cursor-expand>
          Conoce nuestro proceso →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 4. PILARES (teaser) — DESCRIPCIONES REFINADAS                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="pillars-teaser">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Nuestros pilares</p>
        <a href="/scalio#pilares" class="section-link">Ver todo →</a>
      </div>
      <div class="pillars-row">
        <div class="pillar reveal">
          <span class="pillar-num">01</span>
          <h3>Crecimiento</h3>
          <p>
            Cada línea de código, cada elemento visual, cada proceso está
            pensado para multiplicar tu crecimiento, no solo para contar
            historias bonitas.
          </p>
        </div>
        <div class="pillar-divider"></div>
        <div class="pillar reveal">
          <span class="pillar-num">02</span>
          <h3>Innovación</h3>
          <p>
            Tu tecnología crece contigo. No empezamos con una solución pequeña
            que tendrás que reemplazar. Empezamos construyendo para tu futuro.
          </p>
        </div>
        <div class="pillar-divider"></div>
        <div class="pillar reveal">
          <span class="pillar-num">03</span>
          <h3>Confianza</h3>
          <p>
            Trabajamos contigo, no para ti. Significa que ves cada decisión,
            entiendes cada paso y sabes exactamente dónde estás en el camino.
          </p>
        </div>
        <div class="pillar-divider"></div>
        <div class="pillar reveal">
          <span class="pillar-num">04</span>
          <h3>Automatización</h3>
          <p>
            Mientras los procesos corren solos, tú haces el trabajo que importa.
            Automatización que te devuelve tiempo, todos los días.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 5. PROCESO DE TRABAJO — NUEVA SECCIÓN SEO                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- <section id="proceso" class="process-section">
    <div class="container">
      <div class="section-header reveal">
