    padding: 1.1rem 2.5rem;
    font-size: 0.9rem;
  }

  .btn-whatsapp {
    padding: 0.9rem 2.25rem;
    border: 1px solid var(--border);
    color: var(--white-muted);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 100px;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .btn-whatsapp:hover {
    border-color: #25d366;
    color: #25d366;
    background: rgba(37, 211, 102, 0.1);
  }

  .final-cta-trust {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--white-muted);
    margin-bottom: 1rem;
  }

  .final-cta-guarantee {
    font-size: 0.75rem;
    color: var(--white-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .process-grid {
      flex-wrap: wrap;
    }
    .process-step {
      flex: 1 1 45%;
    }
    .process-arrow {
      display: none;
    }
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .pillars-row {
      flex-direction: column;
    }
    .pillar-divider {
      width: 100%;
      height: 1px;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-sub-main {
      font-size: 1.1rem;
    }
    .hero-trust {
      font-size: 0.7rem;
    }
    .project-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .project-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .project-title-group {
      min-width: unset;
    }
    .project-title {
      min-width: unset;
      font-size: 1.25rem;
    }
    .project-arrow {
      margin-left: 0;
    }
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
