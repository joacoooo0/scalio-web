  <!-- 8. TESTIMONIOS — CON ESPECIFICIDAD Y TRUST                     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="testimonials">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Clientes que confiaron en Scalio</p>
        <p class="section-subtitle">Resultados reales de negocios peruanos</p>
      </div>

      <div class="testimonials-grid">
        <blockquote class="testi">
