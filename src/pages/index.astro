      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof gsap === "undefined") return;

    gsap.registerPlugin(ScrollTrigger);

    // ── Hero entrance ──────────────────────
    const tl = gsap.timeline({ delay: 0.3 });

    tl.to(".hero-tag", {
      opacity: 1,
      y: 0,
      duration: 0.7,
      ease: "expo.out",
    })
      .to(
        "#line1",
        {
          y: "0%",
          opacity: 1,
          duration: 1,
          ease: "expo.out",
        },
        "-=0.3",
      )
      .to(
        "#line2",
        {
          y: "0%",
          opacity: 1,
          duration: 1,
          ease: "expo.out",
        },
        "-=0.75",
      )
      .to(
        "#hero-sub",
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "expo.out",
        },
        "-=0.5",
      )
      .to(
        "#scroll-indicator",
        {
          opacity: 1,
          duration: 0.5,
        },
        "-=0.2",
      );

    // ── Statement word reveal ───────────────
    gsap.utils.toArray(".reveal-word").forEach((word, i) => {
      gsap.from(word, {
        scrollTrigger: {
          trigger: word,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 30,
        duration: 0.7,
        delay: i * 0.08,
        ease: "expo.out",
      });
    });

    // ── Generic reveal ──────────────────────
    gsap.utils.toArray(".reveal").forEach((el) => {
      gsap.from(el, {
        scrollTrigger: {
          trigger: el,
          start: "top 88%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 40,
        duration: 0.8,
        ease: "expo.out",
      });
    });

    // ── Project items stagger (container-based) ──────────────
    const projectsList = document.querySelector(".projects-list");
    if (projectsList) {
      gsap.from(".project-item", {
        scrollTrigger: {
          trigger: projectsList,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        x: -30,
        duration: 0.7,
        stagger: 0.12,
        ease: "expo.out",
      });
    }

    // ── Testimonials stagger (container-based) ──────────────
    const testiGrid = document.querySelector(".testimonials-grid");
    if (testiGrid) {
      gsap.from(".testi", {
        scrollTrigger: {
          trigger: testiGrid,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 40,
        duration: 0.7,
        stagger: 0.12,
        ease: "expo.out",
      });
    }

    // ── Horizontal scroll on pillars (desktop) ──
    // Note: .pillar elements also have the generic .reveal animation.
    // We skip the specific stagger here to avoid double-animation conflict.
    // The generic .reveal handler above already covers them.

    // ── Process steps stagger (trigger from container) ──
    // Using container trigger + stagger so all steps in the horizontal flex row
    // animate together reliably, without cumulative delay issues.
    const processGrid = document.querySelector(".process-grid");
    if (processGrid) {
      gsap.from(".process-step", {
        scrollTrigger: {
          trigger: processGrid,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 50,
        duration: 0.7,
        stagger: 0.15,
        ease: "expo.out",
      });
    }

    // ── Benefit cards stagger (trigger from container) ──
    // Same fix as process-steps: use container trigger + stagger.
    const benefitsGrid = document.querySelector(".benefits-grid");
    if (benefitsGrid) {
      gsap.from(".benefit-card", {
        scrollTrigger: {
          trigger: benefitsGrid,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 40,
        duration: 0.7,
        stagger: 0.1,
        ease: "expo.out",
      });
    }

    // ── FAQ items stagger (container-based) ────────────────
    const faqList = document.querySelector(".faq-list");
    if (faqList) {
      gsap.from(".faq-item", {
        scrollTrigger: {
          trigger: faqList,
          start: "top 85%",
          toggleActions: "play none none none",
          once: true,
        },
        opacity: 0,
        y: 30,
        duration: 0.6,
        stagger: 0.08,
        ease: "expo.out",
      });
    }

    // ── Final CTA ───────────────────────────
    gsap.from(".final-cta-content", {
      scrollTrigger: {
        trigger: ".final-cta",
        start: "top 80%",
        toggleActions: "play none none none",
        once: true,
      },
      opacity: 0,
      y: 60,
      duration: 1,
      ease: "expo.out",
    });
  });
</script>
