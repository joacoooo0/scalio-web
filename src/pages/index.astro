                  Captación de leads 100% automatizada
                </p>
              </div>
              <div class="project-tags">
                <span>Estrategia Digital</span>
                <span>Leads</span>
                <span>SEO</span>
              </div>
              <p class="project-arrow">→</p>
            </div>
          </a>
        </article>

        <article class="project-item" data-cursor-expand>
          <a href="/scalio#proyectos" class="project-link">
            <div class="project-media">
              <div class="project-thumb thumb-3">
                <div class="project-thumb-inner"></div>
              </div>
            </div>
            <div class="project-meta">
              <div class="project-title-group">
                <h3 class="project-title">Servicio de Reparación</h3>
                <p class="project-result">
                  Atención WhatsApp 24/7 sin aumentar personal
                </p>
              </div>
              <div class="project-tags">
                <span>Automatización</span>
                <span>WhatsApp</span>
                <span>CRM</span>
              </div>
              <p class="project-arrow">→</p>
            </div>
          </a>
        </article>
      </div>

      <div class="projects-cta reveal">
        <a href="/contacto" class="btn-ghost" data-cursor-expand>
          ¿Quieres resultados así? Cotiza tu proyecto →
        </a>
      </div>
