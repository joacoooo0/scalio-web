---
import ServicioTemplate from '../../layouts/ServicioTemplate.astro';

const benefits = [
  "Aumenta tu visibilidad en Google y aparece en las primeras posiciones",
  "Genera confianza con una presencia online profesional y moderna",
  "Convierte visitantes en clientes con diseño orientado a conversiones",
  "Adaptable 100% a móviles, tablets y computadoras",
  "Carga ultrarrápida para no perder visitantes impacientes",
  "Integración con WhatsApp, redes sociales y pasarelas de pago peruanas"
];

const features = [
  {
    title: "Diseño UX/UI estratégico",
    desc: "Interfaces pensadas para guiar al usuario hacia la acción: cotizar, comprar o contactar."
  },
  {
    title: "SEO técnico incluido",
    desc: "Estructura semántica, meta tags optimizados, velocidad de carga y datos estructurados."
  },
  {
    title: "CMS fácil de usar",
    desc: "Gestiona tu contenido sin saber programar. Actualiza textos, imágenes y productos."
  },
  {
    title: "Hosting y SSL incluidos",
    desc: "Certificado de seguridad HTTPS y hosting en servidores rápidos por 1 año."
  },
  {
    title: "Analytics configurado",
    desc: "Google Analytics 4 y Search Console listos para medir resultados desde el día 1."
  },
  {
    title: "Soporte post-lanzamiento",
    desc: "30 días de soporte gratuito para ajustes y capacitación."
  }
];

const faqs = [
  {
    q: "¿Cuánto cuesta una página web en Lima, Perú?",
    a: "En Scalio ofrecemos desarrollo web estratégico desde S/999. El precio final depende de la cantidad de páginas, funcionalidades especiales (tienda online, reservas, etc.) y si necesitas branding. Solicita una cotización personalizada sin compromiso."
  },
  {
    q: "¿Cuánto tiempo tardan en entregar una web?",
    a: "Una landing page o web corporativa básica toma entre 2 y 3 semanas. Proyectos más complejos como e-commerce o plataformas personalizadas pueden tomar de 4 a 8 semanas. Siempre entregamos con fecha exacta."
  },
  {
    q: "¿Las páginas web incluyen dominio y hosting?",
    a: "Incluimos hosting y certificado SSL por el primer año. El dominio (.com o .pe) puede gestionarlo el cliente o nosotros como valor agregado."
  },
  {
    q: "¿Puedo editar mi página web yo mismo?",
    a: "Sí, todas nuestras webs incluyen un panel de administración intuitivo. Además te capacitamos para que puedas hacer cambios básicos sin depender de un desarrollador."
  }
];
---

<ServicioTemplate
  title="Desarrollo Web Perú | Scalio - Páginas Web que Venden en Lima"
  description="Desarrollo web profesional en Lima, Perú. Creamos páginas web estratégicas, landing pages y tiendas online para MYPES y emprendedores. SEO incluido. Cotiza gratis."
  keyword="desarrollo web Perú"
  serviceName="Desarrollo Web"
  serviceIcon="🚀"
  benefits={benefits}
  features={features}
  faqs={faqs}
  ctaText="Cotizar mi página web"
/>
