---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Gracias | Scalio"
  description="Gracias por contactarnos. Te responderemos en menos de 24 horas."
  canonical="/gracias"
  noindex={true}
>
  <Nav />

  <main
    style="min-height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 2rem;"
  >
    <span style="font-size: 4rem; margin-bottom: 1rem;">🎉</span>
    <h1 style="font-size: 2rem; margin-bottom: 1rem;">
      ¡Mensaje enviado con éxito!
    </h1>
    <p
      style="color: var(--text-secondary, #64748b); max-width: 500px; line-height: 1.6; margin-bottom: 2rem;"
    >
      Gracias por contactar a Scalio. Hemos recibido tu solicitud y te
      responderemos en menos de <strong>24 horas</strong> con una propuesta personalizada.
    </p>
    <p style="color: var(--text-secondary, #64748b); margin-bottom: 2rem;">
      Mientras tanto, ¿quieres ver más de nuestro trabajo?
    </p>
    <div
      style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;"
    >
      <a
        href="/"
        style="background: var(--accent, #3b82f6); color: white; padding: 0.875rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; min-height: 48px;"
      >
        Volver al inicio
      </a>
      <a
        href="/servicios/desarrollo-web"
        style="border: 2px solid var(--accent, #3b82f6); color: var(--accent, #3b82f6); padding: 0.875rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; min-height: 48px;"
      >
        Ver servicios
      </a>
    </div>
  </main>

  <Footer />
</Layout>
